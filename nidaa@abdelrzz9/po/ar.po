msgid "Resolving location…"
msgstr "جارٍ تحديد الموقع…"

msgid "Nidaa"
msgstr "نِداء"

msgid "Fajr"
msgstr "الفجر"

msgid "Sunrise"
msgstr "الشروق"

msgid "Dhuhr"
msgstr "الظهر"

msgid "Asr"
msgstr "العصر"

msgid "Maghrib"
msgstr "المغرب"

msgid "Isha"
msgstr "العشاء"

msgid "Suhoor"
msgstr "السحور"

msgid "Iftar"
msgstr "الإفطار"

